{
  "expo": {
    "name": "Sylana Vessel",
    "slug": "sylana-vessel-app",
    "scheme": "sylanavessel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lysara.vessel"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": false,
      "package": "com.lysara.vessel",
      "minSdkVersion": 26,
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_EXTERNAL_STORAGE",
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withHealthConnectFix",
      [
        "react-native-health-connect",
        {
          "NSHealthShareUsageDescription": "Vessel reads your health data to provide personalized insights and track your wellbeing.",
          "NSHealthUpdateUsageDescription": "Vessel needs access to update your health data."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Vessel accesses your photo library so you can share moments in chat.",
          "cameraPermission": "Vessel uses your camera so you can capture and share photos in chat.",
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#a855f7"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Vessel uses your microphone so you can dictate messages and talk in live voice mode."
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Vessel can use your camera for future video calling features.",
          "microphonePermission": "Vessel uses your microphone for realtime live voice sessions."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7bae1c22-dae4-4eef-96a6-2e9be3f7dbce"
      }
    },
    "owner": "whippybuckle"
  }
}
